# 招标采购微服务环境变量示例
# 复制此文件为 .env 并填入实际值

# ─── 后端配置 ────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://procurement:CHANGE_ME@localhost:5432/procurement
JWT_SECRET_KEY=CHANGE_ME_USE_SAME_SECRET_AS_EAIFLOW
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

API_PREFIX=/api/v1
HOST=0.0.0.0
PORT=3001
LOG_LEVEL=INFO

# ─── 前端配置 ────────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_BASE_URL=
NEXT_PUBLIC_APP_BASE_URL=
