# EAI Business Services Environment Configuration
# Copy this file to .env and configure as needed

# Database Configuration
DATABASE_URL=postgresql://postgres:postgres@eai-flow-postgres-ext:5432/postgres

# RAGFlow Configuration
RAGFLOW_BASE_URL=http://eai-flow-ragflow:9380
RAGFLOW_API_KEY=your-ragflow-api-key

# Service Ports (Internal)
# PROCUREMENT_BACKEND_PORT=3001
# ASSET_BACKEND_PORT=3002
# PROJECT_BACKEND_PORT=3003

# Frontend Ports (External)
# PROCUREMENT_FRONTEND_PORT=3004
# ASSET_FRONTEND_PORT=3005
# PROJECT_FRONTEND_PORT=3006

# Environment
NODE_ENV=development
PYTHON_ENV=development
