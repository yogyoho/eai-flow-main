# EAIFlow Docker 环境配置文件
# 用于连接到外部 postgres-ext 和 ragflow 服务的部署

# ─────────────────────────────────────────────────────────────────────────────
# 外部服务连接 (必须使用外部容器名称)
# ─────────────────────────────────────────────────────────────────────────────

# 外部 Postgres 数据库 (容器名: eai-flow-postgres-ext)
# 端口映射: 主机 5434 -> 容器 5432
EXTENSIONS_DB_HOST=eai-flow-postgres-ext
EXTENSIONS_DB_PORT=5432
EXTENSIONS_DB_USER=agentflow
EXTENSIONS_DB_PASSWORD=agentflow123
EXTENSIONS_DB_NAME=agentflow

# RAGFlow 服务 (容器名: eai-flow-ragflow)
# 端口映射: 主机 9380 -> 容器 9380
RAGFLOW_BASE_URL=http://eai-flow-ragflow:9380
RAGFLOW_API_KEY=
RAGFLOW_TIMEOUT=30

# ─────────────────────────────────────────────────────────────────────────────
# JWT 配置 (所有服务共享)
# ─────────────────────────────────────────────────────────────────────────────
JWT_SECRET=18HVPVD7LLyl9y7O4lwKyxqhZyDOnn6wT68tSd4MgJhbFcOicSgyAF2YBBXStm1E
JWT_SECRET_KEY=18HVPVD7LLyl9y7O4lwKyxqhZyDOnn6wT68tSd4MgJhbFcOicSgyAF2YBBXStm1E
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# Better Auth Secret (frontend session)
BETTER_AUTH_SECRET=your-better-auth-secret-change-in-production

# ─────────────────────────────────────────────────────────────────────────────
# DeerFlow 路径配置
# ─────────────────────────────────────────────────────────────────────────────
DEER_FLOW_HOME=/app/backend/.deer-flow
DEER_FLOW_CONFIG_PATH=/app/config.yaml
DEER_FLOW_EXTENSIONS_CONFIG_PATH=/app/extensions_config.json
DEER_FLOW_DOCKER_SOCKET=/var/run/docker.sock
DEER_FLOW_REPO_ROOT=/app
DEER_FLOW_HOST_BASE_DIR=${DEER_FLOW_HOME}
DEER_FLOW_HOST_SKILLS_PATH=/app/skills

# ─────────────────────────────────────────────────────────────────────────────
# API Keys
# ─────────────────────────────────────────────────────────────────────────────
SILICONFLOW_API_KEY=sk-wiftqbyljprevqolxvcbvjguplbnuqgdunflrmcrbejnsnlj
TAVILY_API_KEY=your-tavily-api-key
JINA_API_KEY=your-jina-api-key
INFOQUEST_API_KEY=your-infoquest-api-key
OPENAI_API_KEY=sk-wiftqbyljprevqolxvcbvjguplbnuqgdunflrmcrbejnsnlj

# ─────────────────────────────────────────────────────────────────────────────
# 微服务数据库连接
# ─────────────────────────────────────────────────────────────────────────────
PROCUREMENT_DATABASE_URL=postgresql+asyncpg://procurement:procurement123@procurement-db:5432/procurement
PROCUREMENT_DB_PASSWORD=procurement123

ASSET_DATABASE_URL=postgresql+asyncpg://asset:asset123@asset-db:5432/asset
ASSET_DB_PASSWORD=asset123

PROJECT_DATABASE_URL=postgresql+asyncpg://project:project123@project-db:5432/project
PROJECT_DB_PASSWORD=project123

# ─────────────────────────────────────────────────────────────────────────────
# LangGraph 配置
# ─────────────────────────────────────────────────────────────────────────────
LANGGRAPH_JOBS_PER_WORKER=10
LANGGRAPH_ALLOW_BLOCKING=0

# ─────────────────────────────────────────────────────────────────────────────
# Gateway 配置
# ─────────────────────────────────────────────────────────────────────────────
GATEWAY_WORKERS=4

# ─────────────────────────────────────────────────────────────────────────────
# 日志级别
# ─────────────────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
