#!/usr/bin/env bash
# =============================================================================
# merge-rules.env — 文件分类规则定义
#
# 三类策略:
#   keep-local       — 纯本地文件, merge 冲突时自动保留本地版本 (ours)
#   accept-upstream  — 纯 upstream 文件, 冲突时自动接受 upstream (theirs)
#   manual-merge     — 双方都有修改, 冲突时标记出来人工判断
#
# 用法: 在 merge 系列脚本中 source 本文件
#   source "$(dirname "$0")/merge-rules.env"
# =============================================================================

# =============================================================================
# keep-local: 本地独占文件 — merge 冲突时保留本地版本
# 这些目录/文件在上游 (bytedance/deer-flow) 中不存在或不应被上游覆盖
# =============================================================================
KEEP_LOCAL_PATTERNS=(
    # --- 本地扩展后端 ---
    "backend/app/extensions/"

    # --- 本地扩展前端 ---
    "frontend/src/extensions/"

    # --- 本地扩展页面 ---
    "frontend/src/app/docmgr/"
    "frontend/src/app/writing/"
    "frontend/src/app/login/"
    "frontend/src/app/settings/"
    "frontend/src/app/admin/"
    "frontend/src/app/knowledge-factory/"

    # --- 系统品牌化 ---
    "frontend/src/app/layout.tsx"
    "frontend/src/core/i18n/locales/"
    "frontend/src/components/landing-new/"

    # --- 业务服务 ---
    "business/"

    # --- Docker 编排 (本地自定义) ---
    "docker/docker-compose.extensions.yaml"
    "docker/docker-compose.ragflow.yaml"
    "docker/docker-compose.business.yaml"
    "docker/docker-compose.external.yaml"
    "docker/.env.docker"

    # --- Nginx 配置 (本地自定义路由) ---
    "docker/nginx/nginx.conf"
    "docker/nginx/ragflow-web.conf"

    # --- 本地工具 ---
    "manage.sh"
    "backend/extensions_config.json"
)

# =============================================================================
# accept-upstream: 跟随上游文件 — 冲突时接受 upstream 版本
# 这些目录/文件由上游维护, 本地通常不做修改
# =============================================================================
ACCEPT_UPSTREAM_PATTERNS=(
    # --- 前端自动生成组件 ---
    "frontend/src/components/ui/"
    "frontend/src/components/ai-elements/"

    # --- 本系统不使用的 Landing 页 ---
    "frontend/src/components/landing/"

    # --- 前端依赖锁文件 (与 package.json 绑定) ---
    "frontend/pnpm-lock.yaml"
)

# =============================================================================
# manual-merge: 双方都修改 — 冲突时标记出来人工判断
# 不在 keep-local 和 accept-upstream 中的文件默认归入此类
# 以下仅列出最常冲突的关键文件作为提醒
# =============================================================================
MANUAL_MERGE_HIGHLIGHTS=(
    "backend/config.yaml"
    "backend/pyproject.toml"
    "backend/uv.lock"
    "backend/app/gateway/__init__.py"
    "backend/app/gateway/app.py"
    "backend/packages/harness/deerflow/agents/memory/"
    "backend/packages/harness/deerflow/config/paths.py"
    "backend/packages/harness/deerflow/persistence/"
    "docker/docker-compose.yaml"
    "frontend/src/app/workspace/layout.tsx"
    "frontend/src/app/workspace/"
    "frontend/src/components/workspace/workspace-sidebar.tsx"
    "frontend/src/components/workspace/workspace-nav-menu.tsx"
    "frontend/src/components/workspace/workspace-nav-chat-list.tsx"
    "frontend/src/components/workspace/recent-chat-list.tsx"
    "frontend/src/components/workspace/welcome.tsx"
    "frontend/src/components/workspace/agent-welcome.tsx"
    "frontend/src/components/workspace/workspace-header.tsx"
    "frontend/src/components/workspace/workspace-container.tsx"
    "frontend/src/components/workspace/settings/about.md"
    "frontend/src/components/workspace/settings/about-settings-page.tsx"
    "frontend/src/content/"
)

# --- 备份目录 ---
MERGE_BACKUP_DIR=".merge-backup"

# =============================================================================
# Helper: 判断文件是否匹配某个 pattern 列表
# 用法: _match_any "file/path" "${ARRAY[@]}"
# 返回: 0 匹配, 1 不匹配
# =============================================================================
_match_any() {
    local file="$1"
    shift
    local patterns=("$@")
    for pattern in "${patterns[@]}"; do
        # 目录 pattern (以 / 结尾) — 匹配目录下所有文件
        if [[ "$pattern" == */ ]]; then
            if [[ "$file" == "$pattern"* ]]; then
                return 0
            fi
        # 精确文件 match — 支持 glob 通配
        elif [[ "$file" == $pattern ]]; then
            return 0
        fi
    done
    return 1
}

# =============================================================================
# classify_file: 对单个文件进行分类
# 用法: classify_file "file/path"
# 输出: keep-local | accept-upstream | manual-merge
# =============================================================================
classify_file() {
    local file="$1"

    if _match_any "$file" "${KEEP_LOCAL_PATTERNS[@]}"; then
        echo "keep-local"
    elif _match_any "$file" "${ACCEPT_UPSTREAM_PATTERNS[@]}"; then
        echo "accept-upstream"
    else
        echo "manual-merge"
    fi
}

# =============================================================================
# backup_keep_local: 备份所有 keep-local 文件到 MERGE_BACKUP_DIR
# 保留目录结构
# =============================================================================
backup_keep_local() {
    local backup_dir="${1:-$MERGE_BACKUP_DIR}"
    local repo_root
    repo_root="$(git rev-parse --show-toplevel 2>/dev/null || pwd)"

    echo "=== Backing up keep-local files to ${backup_dir}/ ==="
    rm -rf "${repo_root}/${backup_dir}"
    mkdir -p "${repo_root}/${backup_dir}"

    local count=0
    for pattern in "${KEEP_LOCAL_PATTERNS[@]}"; do
        if [[ "$pattern" == */ ]]; then
            # 目录 pattern — 复制整个目录树
            local dir_path="${repo_root}/${pattern}"
            if [[ -d "$dir_path" ]]; then
                mkdir -p "${repo_root}/${backup_dir}/${pattern}"
                cp -r "$dir_path"* "${repo_root}/${backup_dir}/${pattern}" 2>/dev/null || true
                local n
                n=$(find "$dir_path" -type f 2>/dev/null | wc -l)
                count=$((count + n))
                echo "  [dir]  ${pattern} (${n} files)"
            fi
        else
            # 文件 pattern
            local file_path="${repo_root}/${pattern}"
            if [[ -f "$file_path" ]]; then
                mkdir -p "$(dirname "${repo_root}/${backup_dir}/${pattern}")"
                cp "$file_path" "${repo_root}/${backup_dir}/${pattern}"
                count=$((count + 1))
                echo "  [file] ${pattern}"
            fi
        fi
    done
    echo "  Total: ${count} files backed up"
}

# =============================================================================
# restore_keep_local: 从 MERGE_BACKUP_DIR 恢复所有 keep-local 文件
# =============================================================================
restore_keep_local() {
    local backup_dir="${1:-$MERGE_BACKUP_DIR}"
    local repo_root
    repo_root="$(git rev-parse --show-toplevel 2>/dev/null || pwd)"

    if [[ ! -d "${repo_root}/${backup_dir}" ]]; then
        echo "ERROR: Backup directory ${backup_dir}/ not found. Run pre-merge.sh first."
        return 1
    fi

    echo "=== Restoring keep-local files from ${backup_dir}/ ==="
    local count=0
    for pattern in "${KEEP_LOCAL_PATTERNS[@]}"; do
        local src="${repo_root}/${backup_dir}/${pattern}"
        if [[ "$pattern" == */ ]]; then
            if [[ -d "$src" ]]; then
                mkdir -p "${repo_root}/${pattern}"
                cp -r "$src"* "${repo_root}/${pattern}" 2>/dev/null || true
                local n
                n=$(find "$src" -type f 2>/dev/null | wc -l)
                count=$((count + n))
                echo "  [dir]  ${pattern} (${n} files)"
            fi
        else
            if [[ -f "$src" ]]; then
                cp "$src" "${repo_root}/${pattern}"
                count=$((count + 1))
                echo "  [file] ${pattern}"
            fi
        fi
    done
    echo "  Total: ${count} files restored"
}

# =============================================================================
# list_keep_local_files: 列出所有实际存在的 keep-local 文件
# 用法: list_keep_local_files
# =============================================================================
list_keep_local_files() {
    local repo_root
    repo_root="$(git rev-parse --show-toplevel 2>/dev/null || pwd)"

    for pattern in "${KEEP_LOCAL_PATTERNS[@]}"; do
        if [[ "$pattern" == */ ]]; then
            find "${repo_root}/${pattern}" -type f 2>/dev/null || true
        elif [[ -f "${repo_root}/${pattern}" ]]; then
            echo "${repo_root}/${pattern}"
        fi
    done
}
