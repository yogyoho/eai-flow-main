      "validationConfig": {
        "fields": [
          {"fieldName": "SO2年均浓度", "limit": 150, "unit": "μg/m³", "standard": "GB3095-2012 二类区"},
          {"fieldName": "NO2年均浓度", "limit": 80, "unit": "μg/m³", "standard": "GB3095-2012 二类区"},
          {"fieldName": "PM10年均浓度", "limit": 150, "unit": "μg/m³", "standard": "GB3095-2012 二类区"},
