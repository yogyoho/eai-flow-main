          {"fieldName": "CO日均值", "limit": 4000, "unit": "μg/m³", "standard": "GB3095-2012 二类区"},
          {"fieldName": "O3日最大8小时平均", "limit": 160, "unit": "μg/m³", "standard": "GB3095-2012 二类区"}
