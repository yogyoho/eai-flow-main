        "comparisonType": "max_limit"
      },
      "errorMessage": "{field}浓度为{value}{unit}，超过GB3095-2012二级标准限值{limit}{unit}",
      "autoFixSuggestion": "需采取大气污染防治措施，确保污染物排放达标"
